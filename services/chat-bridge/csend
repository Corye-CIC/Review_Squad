#!/bin/bash
# csend — fire-and-forget chat message sender for Review Squad agents
# Usage: csend <agent> <level> <message>
#   agent: emily | fc | jared | stevey | pm-cory | nando
#   level: phase | decision | conversation
# Failures are always silent — never breaks agent execution.
# Always appends to /tmp/agent-chat-log.md regardless of server state.

set -euo pipefail

agent="${1:-}"
level="${2:-}"
message="${3:-}"

if [ -z "$agent" ] || [ -z "$level" ] || [ -z "$message" ]; then
  exit 0
fi

LOG_FILE="/tmp/agent-chat-log.md"

# Always write to local log — captured even if /agent-chat:on was never run.
# When the server IS running, its auto-save periodically rewrites this file
# with an authoritative formatted version. When it's NOT running, these
# appends accumulate a running log.
{
  if [ ! -s "$LOG_FILE" ]; then
    printf '# Agent Chat Log\n\n**Started:** %s\n\n' "$(date -Iseconds)"
  fi
  printf -- '---\n\n**%s** · %s · %s\n\n%s\n\n' \
    "$(date +%H:%M:%S)" "$agent" "$level" "$message"
} >> "$LOG_FILE" 2>/dev/null || true

# Try to send to bridge (fire-and-forget)
port="${CHAT_BRIDGE_PORT:-4002}"
body=$(jq -n --arg a "$agent" --arg l "$level" --arg m "$message" \
  '{agent: $a, level: $l, message: $m}')

curl -s --max-time 1 \
  -X POST \
  -H "Content-Type: application/json" \
  -d "$body" \
  "http://127.0.0.1:${port}/send" \
  > /dev/null 2>&1 || true
